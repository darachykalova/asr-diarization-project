    {
      "name": "Metrics",
      "item": [
        {
          "name": "GET /metrics (Prometheus)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/metrics",
            "header": [
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "pm.test('Prometheus format', () => { pm.expect(pm.response.text()).to.include('# HELP'); });"
                ]
              }
            }
          ]
