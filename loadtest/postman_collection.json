    },
    {
      "name": "Submit (async)",
      "item": [
        {
          "name": "POST /v1/transcriptions/upload → 202",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/v1/transcriptions/upload",
            "header": [
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "audio_short.mp3",
                  "description": "Replace with path to a short audio file (5-15 sec)"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('202 accepted', () => pm.response.to.have.status(202));",
                  "pm.test('has job_id', () => { const b = pm.response.json(); pm.expect(b).to.have.property('job_id'); });",
                  "pm.test('status=queued', () => { const b = pm.response.json(); pm.expect(b.status).to.eql('queued'); });",
                  "if (pm.response.code === 202) { pm.environment.set('last_job_id', pm.response.json().job_id); }"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
