{
  "info": {
    "name": "ASR Diarization API — Load Test",
    "description": "Coverage: all ТЗ endpoints. Use Postman Performance (1 min, 5+ virtual users) to hit 50 req/min target.\n\nSetup: import postman_environment.json, disable SSL verification in Postman Settings.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /healthz",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/healthz"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 ok', () => pm.response.to.have.status(200));",
                  "pm.test('status=ok', () => { const b = pm.response.json(); pm.expect(b.status).to.eql('ok'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /readyz",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/readyz"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 ready', () => pm.response.to.have.status(200));",
                  "pm.test('status=ready', () => { const b = pm.response.json(); pm.expect(b.status).to.eql('ready'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth checks",
      "item": [
        {
          "name": "No key → 401",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/transcripts"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('401 without key', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "GET /v1/jobs/{done_job_id}",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/jobs/{{done_job_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "pm.test('has job_id', () => { const b = pm.response.json(); pm.expect(b).to.have.property('job_id'); });",
                  "pm.test('status=done', () => { const b = pm.response.json(); pm.expect(b.status).to.eql('done'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /v1/jobs/{unknown} → 404",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/jobs/00000000-0000-0000-0000-000000000000",
            "header": [
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('404 for unknown job', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Transcripts",
      "item": [
        {
          "name": "GET /v1/transcripts (list)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/transcripts?page=1&page_size=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "10" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "pm.test('has items array', () => { const b = pm.response.json(); pm.expect(b).to.have.property('items'); pm.expect(b.items).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /v1/transcripts/{done_job_id}",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/transcripts/{{done_job_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "pm.test('has speakers array', () => { const b = pm.response.json(); pm.expect(b).to.have.property('speakers'); });",
                  "pm.test('has transcript.segments', () => { const b = pm.response.json(); pm.expect(b.transcript.segments).to.be.an('array'); });",
                  "pm.test('segments have words', () => { const segs = pm.response.json().transcript.segments; if (segs.length > 0) { pm.expect(segs[0]).to.have.property('words'); } });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /v1/transcripts/{id}/segments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/transcripts/{{done_job_id}}/segments?page=1&page_size=20",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "20" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "pm.test('has items', () => { const b = pm.response.json(); pm.expect(b).to.have.property('items'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /v1/transcripts/{id}/export?format=srt",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/transcripts/{{done_job_id}}/export?format=srt",
              "query": [
                { "key": "format", "value": "srt" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "pm.test('SRT content-type', () => { pm.expect(pm.response.headers.get('content-type')).to.include('text'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /v1/transcripts/{id}/export?format=vtt",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/transcripts/{{done_job_id}}/export?format=vtt",
              "query": [
                { "key": "format", "value": "vtt" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{api_key}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 vtt', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },
