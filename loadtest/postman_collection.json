    {
      "name": "🔄 WORKFLOW (запускать вручную через Run, не Performance)",
      "description": "Полный сценарий: POST upload → polling статуса → GET результата.\nPostman Performance не умеет прикреплять бинарные файлы, поэтому этот сценарий запускать только через обычный Collection Run.",
      "item": [
        {
          "name": "1. POST /v1/transcriptions/upload → 202",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/v1/transcriptions/upload",
            "header": [{ "key": "Authorization", "value": "Bearer {{api_key}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [{
                "key": "file",
                "type": "file",
                "src": "audio_short_15s.mp3"
              }]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('202 accepted', () => pm.response.to.have.status(202));",
            "pm.test('has job_id', () => pm.expect(pm.response.json()).to.have.property('job_id'));",
            "if (pm.response.code === 202) {",
            "  const jobId = pm.response.json().job_id;",
            "  pm.environment.set('workflow_job_id', jobId);",
            "  pm.collectionVariables.set('workflow_job_id', jobId);",
            "  console.log('Submitted job_id:', jobId);",
            "}"
          ]}}]
        },
        {
          "name": "2. Poll GET /v1/jobs/{{workflow_job_id}} (автоповтор до done)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/jobs/{{workflow_job_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{api_key}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const b = pm.response.json();",
            "pm.test('200', () => pm.response.to.have.status(200));",
            "console.log('Status:', b.status, '| Progress:', b.progress);",
            "pm.test('not failed', () => pm.expect(b.status).to.not.eql('failed'));",
            "if (b.status !== 'done' && b.status !== 'failed' && b.status !== 'partial') {",
            "  postman.setNextRequest('2. Poll GET /v1/jobs/{{workflow_job_id}} (автоповтор до done)');",
            "} else {",
            "  console.log('Job finished:', b.status);",
            "}"
          ]}}]
        },
        {
          "name": "3. GET /v1/transcripts/{{workflow_job_id}}",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/transcripts/{{workflow_job_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{api_key}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('has speakers', () => pm.expect(b).to.have.property('speakers'));",
            "pm.test('has segments with words', () => {",
            "  const segs = b.transcript.segments;",
            "  pm.expect(segs.length).to.be.above(0);",
            "  pm.expect(segs[0]).to.have.property('words');",
            "});"
          ]}}]
        }
      ]
    }
