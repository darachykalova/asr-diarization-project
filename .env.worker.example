# Copy to .env.worker and fill in the infrastructure host details.

POSTGRES_DB=asr_db
POSTGRES_USER=asr_user
POSTGRES_PASSWORD=asr_password

REDIS_URL=redis://192.168.1.10:6379/0
REDIS_BACKEND_URL=redis://192.168.1.10:6379/1
DATABASE_URL=postgresql+psycopg://asr_user:asr_password@192.168.1.10:5432/asr_db

QDRANT_HOST=192.168.1.10
QDRANT_PORT=6333

MINIO_ENDPOINT=192.168.1.10:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin12345
MINIO_BUCKET=audio-files
MINIO_MODELS_BUCKET=ml-models

HF_TOKEN=hf_your_token_here
HF_HUB_DISABLE_XET=1

SPEAKER_MATCH_THRESHOLD=0.70
LOG_LEVEL=INFO

# Pipeline mode: 'monolith' (default, safe fallback) or 'chain' (split tasks)
PIPELINE_MODE=monolith
